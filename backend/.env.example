# ---- Google Gemini (powers ALL text generation + text-to-speech) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Optional model overrides
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# ---- NeonDB (optional — stores a history of generated content) ----
# Copy the connection string from your Neon project dashboard.
# Leave blank to run without a database (everything still works).
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
